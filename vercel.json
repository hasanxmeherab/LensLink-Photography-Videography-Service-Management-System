{
  "version": 2,
  "buildCommand": "cd client && npm run build && cd ../server && npm install",
  "outputDirectory": "client/build",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/client/build/index.html"
    }
  ]
}
